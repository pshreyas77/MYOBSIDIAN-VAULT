ge_obsidianvault_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "e_knowledge_obsidianvault_gitnexus_gitnexus_src_core_lbug_pool_adapter_ts", "relation": "imports_from", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L14", "weight": 1.0}, {"source": "e_knowledge_obsidianvault_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "embedder_initembedder", "relation": "contains", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L27", "weight": 1.0}, {"source": "e_knowledge_obsidianvault_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "embedder_isembedderready", "relation": "contains", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L100", "weight": 1.0}, {"source": "e_knowledge_obsidianvault_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "embedder_embedquery", "relation": "contains", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L105", "weight": 1.0}, {"source": "e_knowledge_obsidianvault_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "embedder_getembeddingdims", "relation": "contains", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L123", "weight": 1.0}, {"source": "e_knowledge_obsidianvault_gitnexus_gitnexus_src_mcp_core_embedder_ts", "target": "embedder_disposeembedder", "relation": "contains", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L130", "weight": 1.0}, {"source": "embedder_embedquery", "target": "embedder_initembedder", "relation": "calls", "confidence": "EXTRACTED", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L110", "weight": 1.0}], "raw_calls": [{"caller_nid": "embedder_initembedder", "callee": "isHttpMode", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L28"}, {"caller_nid": "embedder_initembedder", "callee": "(async () => {\n    try {\n      env.allowLocalModels = false;\n      // Default cache to user-writable location. transformers.js defaults to\n      // ./node_modules/.cache inside its own install dir, which is unwritable\n      // when gitnexus is installed globally (e.g. /usr/lib/node_modules/).\n      // Respect HF_HOME if set, otherwise fall back to ~/.cache/huggingface.\n      env.cacheDir = process.env.HF_HOME ?? `${process.env.HOME}/.cache/huggingface`;\n\n      console.error('GitNexus: Loading embedding model (first search may take a moment)...');\n\n      // Try GPU first (DirectML on Windows, CUDA on Linux), fall back to CPU\n      const isWindows = process.platform === 'win32';\n      const gpuDevice = isWindows ? 'dml' : 'cuda';\n      const devicesToTry: Array<'dml' | 'cuda' | 'cpu'> = [gpuDevice, 'cpu'];\n\n      for (const device of devicesToTry) {\n        try {\n          // Silence stdout and stderr during model load \u2014 ONNX Runtime and transformers.js\n          // may write progress/init messages that corrupt MCP stdio protocol or produce\n          // noisy warnings (e.g. node assignment to execution providers).\n          // Use the centralized silenceStdout() to avoid conflicts with pool-adapter's\n          // own stdout patching (independent patching caused restore-order bugs).\n          silenceStdout();\n          process.stderr.write = (() => true) as any;\n          try {\n            embedderInstance = await (pipeline as any)('feature-extraction', MODEL_ID, {\n              device: device,\n              dtype: 'fp32',\n            });\n          } finally {\n            restoreStdout();\n            process.stderr.write = realStderrWrite;\n          }\n          console.error(`GitNexus: Embedding model loaded (${device})`);\n          return embedderInstance!;\n        } catch {\n          if (device === 'cpu') throw new Error('Failed to load embedding model');\n        }\n      }\n\n      throw new Error('No suitable device found');\n    } catch (error) {\n      isInitializing = false;\n      initPromise = null;\n      embedderInstance = null;\n      throw error;\n    } finally {\n      isInitializing = false;\n    }\n  })", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L42"}, {"caller_nid": "embedder_isembedderready", "callee": "isHttpMode", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L100"}, {"caller_nid": "embedder_embedquery", "callee": "isHttpMode", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L106"}, {"caller_nid": "embedder_embedquery", "callee": "httpEmbedQuery", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L107"}, {"caller_nid": "embedder_embedquery", "callee": "embedder", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L112"}, {"caller_nid": "embedder_embedquery", "callee": "from", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L117"}, {"caller_nid": "embedder_getembeddingdims", "callee": "getHttpDimensions", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\\mcp\\core\\embedder.ts", "source_location": "L124"}, {"caller_nid": "embedder_disposeembedder", "callee": "dispose", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus\\src\