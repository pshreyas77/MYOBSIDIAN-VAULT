ain_problem_generateembedding", "callee": "charCodeAt", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L102"}, {"caller_nid": "train_problem_generateembedding", "callee": "sqrt", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L113"}, {"caller_nid": "train_problem_generateembedding", "callee": "reduce", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L113"}, {"caller_nid": "train_problem_generateembedding", "callee": "from", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L118"}, {"caller_nid": "train_problem_insertpatterns", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1068"}, {"caller_nid": "train_problem_insertpatterns", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1070"}, {"caller_nid": "train_problem_insertpatterns", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1075"}, {"caller_nid": "train_problem_insertpatterns", "callee": "db.transaction(() => {\n    patterns.forEach((pattern, idx) => {\n      const memoryId = `problem-solving/${pattern.cognitiveType}/${idx}`;\n      const reasoningSteps = JSON.stringify(pattern.reasoning);\n\n      const result = insertPattern.run(\n        memoryId,\n        pattern.problem,\n        reasoningSteps,\n        pattern.outcome,\n        pattern.successRate,\n        pattern.cognitiveType,\n        pattern.domain,\n        pattern.tags\n      );\n\n      // Generate and insert embedding\n      const embedding = generateEmbedding(pattern.problem + ' ' + pattern.solution, pattern.cognitiveType);\n      insertEmbedding.run(result.lastInsertRowid, embedding, 'simulated-384d');\n\n      insertedCount++;\n\n      if (insertedCount % 400 === 0) {\n        console.log(`   \u2713 ${insertedCount}/${patterns.length} patterns inserted`);\n      }\n    });\n  })", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1082"}, {"caller_nid": "train_problem_insertpatterns", "callee": "transaction", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1082"}, {"caller_nid": "train_problem_insertpatterns", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1110"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1115"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "all", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1117"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1117"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1118"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "db.transaction(() => {\n    patterns.forEach((sourcePattern, idx) => {\n      if (linkCount >= targetLinks) return;\n\n      // Create 2-4 links per pattern\n      const numLinks = 2 + Math.floor(Math.random() * 3);\n\n      for (let i = 0; i < numLinks && linkCount < targetLinks; i++) {\n        // Find related pattern\n        const targetIdx = Math.floor(Math.random() * patterns.length);\n        if (targetIdx === idx) continue;\n\n        const targetPattern = patterns[targetIdx];\n\n        // Determine link type based on relationship\n        let linkType, strength;\n\n        if (sourcePattern.cognitive_type === targetPattern.cognitive_type) {\n          linkType = 'alternative';\n          strength = 0.8 + Math.random() * 0.2;\n        } else if (sourcePattern.domain === targetPattern.domain) {\n          linkType = 'enhances';\n          strength = 0.7 + Math.random() * 0.2;\n        } else {\n          linkType = 'requires';\n          strength = 0.6 + Math.random() * 0.3;\n        }\n\n        insertLink.run(sourcePattern.id, targetPattern.id, linkType, strength);\n        linkCount++;\n      }\n\n      if (linkCount % 700 === 0) {\n        console.log(`   \u2713 ${linkCount}/${targetLinks} links created`);\n      }\n    });\n  })", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1126"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "transaction", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1126"}, {"caller_nid": "train_problem_createpatternlinks", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1164"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1169"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "all", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1171"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1171"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1172"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "db.transaction(() => {\n    for (let i = 0; i < targetTrajectories; i++) {\n      const numSteps = 3 + Math.floor(Math.random() * 5); // 3-7 steps\n      const stepPatterns = [];\n\n      // Build trajectory with diverse cognitive patterns\n      const cognitiveTypes = ['convergent', 'divergent', 'lateral', 'systems', 'critical'];\n      const usedTypes = new Set();\n\n      for (let step = 0; step < numSteps; step++) {\n        // Try to use different cognitive types\n        const availableTypes = cognitiveTypes.filter(t => !usedTypes.has(t) || usedTypes.size >= cognitiveTypes.length);\n        const targetType = availableTypes[Math.floor(Math.random() * availableTypes.length)];\n        usedTypes.add(targetType);\n        if (usedTypes.size >= cognitiveTypes.length) usedTypes.clear();\n\n        const candidatePatterns = patterns.filter(p => p.cognitive_type === targetType);\n        const selectedPattern = candidatePatterns[Math.floor(Math.random() * candidatePatterns.length)];\n        stepPatterns.push(selectedPattern.id);\n      }\n\n      const memoryId = `trajectory/problem-solving/${i}`;\n      const stepSequence = JSON.stringify(stepPatterns);\n      const successRate = 0.70 + Math.random() * 0.25;\n\n      insertTrajectory.run(memoryId, stepSequence, numSteps, successRate);\n      trajectoryCount++;\n\n      if (trajectoryCount % 100 === 0) {\n        console.log(`   \u2713 ${trajectoryCount}/${targetTrajectories} trajectories created`);\n      }\n    }\n  })", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1180"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "transaction", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1180"}, {"caller_nid": "train_problem_createtasktrajectories", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1214"}, {"caller_nid": "train_problem_validatedatabase", "callee": "log", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1219"}, {"caller_nid": "train_problem_validatedatabase", "callee": "get", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1221"}, {"caller_nid": "train_problem_validatedatabase", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1221"}, {"caller_nid": "train_problem_validatedatabase", "callee": "get", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruflo/v2/docs/reasoningbank/models/problem-solving/train-problem.js", "source_location": "L1222"}, {"caller_nid": "train_problem_validatedatabase", "callee": "prepare", "source_file": "/home/sunny77/Documents/Obsidian Vault/ruf