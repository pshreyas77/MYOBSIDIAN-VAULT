connect", "callee": "fetchRepos", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L170"}, {"caller_nid": "dropzone_handleautoconnect", "callee": "setPhase", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L172"}, {"caller_nid": "dropzone_handleautoconnect", "callee": "setDetectedRepos", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L178"}, {"caller_nid": "dropzone_handleautoconnect", "callee": "setPhase", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L179"}, {"caller_nid": "dropzone_handleautoconnect", "callee": "setError", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L183"}, {"caller_nid": "dropzone_handleautoconnect", "callee": "setPhase", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L184"}, {"caller_nid": "dropzone_connecttorepo", "callee": "setPhase", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L195"}, {"caller_nid": "dropzone_connecttorepo", "callee": "setLoadingMessage", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L196"}, {"caller_nid": "dropzone_connecttorepo", "callee": "setError", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L197"}, {"caller_nid": "dropzone_connecttorepo", "callee": "(async () => {\n      const abortController = new AbortController();\n      abortControllerRef.current = abortController;\n      try {\n        const result = await connectToServer(\n          detectedBackendUrl,\n          (p, downloaded, total) => {\n            if (p === 'validating') {\n              setLoadingMessage('Validating server...');\n            } else if (p === 'downloading') {\n              const pct = total ? Math.round((downloaded / total) * 100) : null;\n              const mb = (downloaded / (1024 * 1024)).toFixed(1);\n              setLoadingMessage(pct ? `Downloading graph... ${pct}%` : `Downloading... ${mb} MB`);\n            } else if (p === 'extracting') {\n              setLoadingMessage('Processing graph...');\n            }\n          },\n          abortController.signal,\n          repoName,\n        );\n        if (onServerConnect) {\n          await onServerConnect(result, detectedBackendUrl);\n        }\n      } catch (err) {\n        if ((err as Error).name === 'AbortError') return;\n        setError(err instanceof Error ? err.message : 'Failed to load graph');\n        setPhase(detectedRepos.length > 0 ? 'landing' : 'analyze');\n      } finally {\n        abortControllerRef.current = null;\n      }\n    })", "source_file": "E:\\_Knowledge\\ObsidianVault\\GitNexus\\gitnexus-web\\src\\components\\DropZone.tsx", "source_location": "L199"}]}