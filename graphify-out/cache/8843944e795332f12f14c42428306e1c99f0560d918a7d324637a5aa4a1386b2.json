ource_location": "L73"}, {"caller_nid": "embedder_iscudaavailable", "callee": "includes", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L74"}, {"caller_nid": "embedder_iscudaavailable", "callee": "filter", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L84"}, {"caller_nid": "embedder_iscudaavailable", "callee": "split", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L84"}, {"caller_nid": "embedder_iscudaavailable", "callee": "existsSync", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L86"}, {"caller_nid": "embedder_iscudaavailable", "callee": "join", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L86"}, {"caller_nid": "embedder_iscudaavailable", "callee": "existsSync", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L87"}, {"caller_nid": "embedder_iscudaavailable", "callee": "join", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L87"}, {"caller_nid": "embedder_iscudaavailable", "callee": "existsSync", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L88"}, {"caller_nid": "embedder_iscudaavailable", "callee": "join", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L88"}, {"caller_nid": "embedder_initembedder", "callee": "isHttpMode", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L127"}, {"caller_nid": "embedder_initembedder", "callee": "(async () => {\n    try {\n      // Configure transformers.js environment\n      env.allowLocalModels = false;\n      // Default cache to user-writable location. transformers.js defaults to\n      // ./node_modules/.cache inside its own install dir, which is unwritable\n      // when gitnexus is installed globally (e.g. /usr/lib/node_modules/).\n      // Respect HF_HOME if set, otherwise fall back to ~/.cache/huggingface.\n      env.cacheDir = process.env.HF_HOME ?? `${process.env.HOME}/.cache/huggingface`;\n\n      const isDev = process.env.NODE_ENV === 'development';\n      if (isDev) {\n        console.log(`\ud83e\udde0 Loading embedding model: ${finalConfig.modelId}`);\n      }\n\n      const progressCallback = onProgress\n        ? (data: any) => {\n            const progress: ModelProgress = {\n              status: data.status || 'progress',\n              file: data.file,\n              progress: data.progress,\n              loaded: data.loaded,\n              total: data.total,\n            };\n            onProgress(progress);\n          }\n        : undefined;\n\n      // Try GPU first if auto, fall back to CPU\n      // Windows: dml (DirectML/DirectX12), Linux: cuda\n      const devicesToTry: Array<'dml' | 'cuda' | 'cpu' | 'wasm'> =\n        requestedDevice === 'dml' || requestedDevice === 'cuda'\n          ? [requestedDevice, 'cpu']\n          : [requestedDevice as 'cpu' | 'wasm'];\n\n      for (const device of devicesToTry) {\n        try {\n          if (isDev && device === 'dml') {\n            console.log('\ud83d\udd27 Trying DirectML (DirectX12) GPU backend...');\n          } else if (isDev && device === 'cuda') {\n            console.log('\ud83d\udd27 Trying CUDA GPU backend...');\n          } else if (isDev && device === 'cpu') {\n            console.log('\ud83d\udd27 Using CPU backend...');\n          } else if (isDev && device === 'wasm') {\n            console.log('\ud83d\udd27 Using WASM backend (slower)...');\n          }\n\n          embedderInstance = await (pipeline as any)('feature-extraction', finalConfig.modelId, {\n            device: device,\n            dtype: 'fp32',\n            progress_callback: progressCallback,\n            session_options: { logSeverityLevel: 3 },\n          });\n          currentDevice = device;\n\n          if (isDev) {\n            const label =\n              device === 'dml'\n                ? 'GPU (DirectML/DirectX12)'\n                : device === 'cuda'\n                  ? 'GPU (CUDA)'\n                  : device.toUpperCase();\n            console.log(`\u2705 Using ${label} backend`);\n            console.log('\u2705 Embedding model loaded successfully');\n          }\n\n          return embedderInstance!;\n        } catch (deviceError) {\n          if (isDev && (device === 'cuda' || device === 'dml')) {\n            const gpuType = device === 'dml' ? 'DirectML' : 'CUDA';\n            console.log(`\u26a0\ufe0f  ${gpuType} not available, falling back to CPU...`);\n          }\n          // Continue to next device in list\n          if (device === devicesToTry[devicesToTry.length - 1]) {\n            throw deviceError; // Last device failed, propagate error\n          }\n        }\n      }\n\n      throw new Error('No suitable device found for embedding model');\n    } catch (error) {\n      isInitializing = false;\n      initPromise = null;\n      embedderInstance = null;\n      throw error;\n    } finally {\n      isInitializing = false;\n    }\n  })", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L156"}, {"caller_nid": "embedder_isembedderready", "callee": "isHttpMode", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L253"}, {"caller_nid": "embedder_getembeddingdimensions", "callee": "isHttpMode", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L261"}, {"caller_nid": "embedder_getembeddingdimensions", "callee": "getHttpDimensions", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L262"}, {"caller_nid": "embedder_getembedder", "callee": "isHttpMode", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L271"}, {"caller_nid": "embedder_embedtext", "callee": "isHttpMode", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L289"}, {"caller_nid": "embedder_embedtext", "callee": "httpEmbed", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L290"}, {"caller_nid": "embedder_embedtext", "callee": "embedder", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L296"}, {"caller_nid": "embedder_embedbatch", "callee": "isHttpMode", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L317"}, {"caller_nid": "embedder_embedbatch", "callee": "httpEmbed", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L318"}, {"caller_nid": "embedder_embedbatch", "callee": "embedder", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L324"}, {"caller_nid": "embedder_embedbatch", "callee": "push", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L338"}, {"caller_nid": "embedder_embedbatch", "callee": "call", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L338"}, {"caller_nid": "embedder_embeddingtoarray", "callee": "from", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L348"}, {"caller_nid": "embedder_disposeembedder", "callee": "dispose", "source_file": "/home/sunny77/Documents/Obsidian Vault/GitNexus/gitnexus/src/core/embeddings/embedder.ts", "source_location": "L360"}]}