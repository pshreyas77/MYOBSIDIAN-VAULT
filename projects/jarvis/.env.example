# J.A.R.V.I.S. Configuration - FREE VERSION
# Just A Rather Very Intelligent System
#
# Choose ONE of the following backends:
#   1. OLLAMA (RECOMMENDED - Completely FREE, runs locally)
#   2. NVIDIA Free Tier (Free API with generous limits)
#   3. DeepSeek (Free tier available)
#
# For detailed instructions, see SETUP.md

# ============================================
# OPTION 1: OLLAMA (FREE - RECOMMENDED)
# ============================================
# 1. Install: curl -fsSL https://ollama.com/install.sh | sh
# 2. Pull model: ollama pull llama3.2
# 3. Start server: ollama serve
# 4. Set below:

OLLAMA_ENABLED=true
OLLAMA_MODEL=llama3.2
# OLLAMA_MODEL=mistral        # Alternative
# OLLAMA_MODEL=qwen2.5        # Alternative
OLLAMA_HOST=http://localhost:11434

# ============================================
# OPTION 2: NVIDIA (FREE TIER)
# ============================================
# 1. Sign up: https://build.nvidia.com
# 2. Generate API key
# 3. Unset OLLAMA_ENABLED above
# 4. Set below:

# OLLAMA_ENABLED=false
# OPENAI_API_KEY=nvapi-your-key-here
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# OPENAI_MODEL=nvidia/llama-3.1-nemotron-70b-instruct

# ============================================
# OPTION 3: DEEPSEEK (FREE TIER)
# ============================================
# 1. Sign up: https://platform.deepseek.com
# 2. Get API key
# 3. Unset OLLAMA_ENABLED above
# 4. Set below:

# OLLAMA_ENABLED=false
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_BASE_URL=https://api.deepseek.com/v1
# OPENAI_MODEL=deepseek-chat

# ============================================
# OPTION 4: ANTHROPIC (PAID)
# ============================================
# Only use if you already have credits

# ANTHROPIC_API_KEY=sk-ant-api03-your-key

# ============================================
# OBSIDIAN VAULT (Required)
# ============================================
# Will auto-detect, but you can override:

OBSIDIAN_VAULT_PATH=/home/sunny77/Documents/Obsidian Vault

# Install "Local REST API" plugin in Obsidian
# Then copy the API key here:
OBSIDIAN_API_KEY=your-obsidian-api-key-here
OBSIDIAN_API_PORT=27123

# ============================================
# PERSONALIZATION
# ============================================

JARVIS_NAME=J.A.R.V.I.S.
USER_NAME=Sir
WAKE_WORD=jarvis

# ============================================
# FEATURES (Set to true/false)
# ============================================

VOICE_ENABLED=false
TEXT_TO_SPEECH_ENABLED=false
SPEECH_RATE=150

MEMORY_ENABLED=true
MAX_MEMORY_ENTRIES=50

DEBUG_MODE=false
LOG_LEVEL=INFO

# ============================================
# LLM BACKEND PRIORITY
# ============================================
# auto  = try Ollama first, then APIs
# ollama = force local
# anthropic = force Claude
# openai = force OpenAI-compatible

LLM_BACKEND=auto